+}
+
+/* --- Print --- */
+@media print {
+  body { background: #fff; }
+  .sidebar, .notification-bell, .btn-ai, .loading-overlay { display: none !important; }
+  .main-content { margin-left: 0 !important; }
+  .card { box-shadow: none; border: 1px solid #ccc; break-inside: avoid; }
+}
