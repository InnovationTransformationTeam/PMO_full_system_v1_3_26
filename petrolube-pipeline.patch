+
+/* --- AI Generated Marker --- */
+.ai-generated {
+  border-left: 3px solid #764ba2;
+  padding-left: 12px;
+}
+
+/* --- Data Table --- */
+.data-table {
+  width: 100%;
+  border-collapse: collapse;
+  font-size: 13px;
+}
+.data-table th,
+.data-table td {
+  padding: 10px 14px;
+  text-align: left;
